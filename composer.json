{
  "name": "mobikul/mobikul_loader",
  "description": "Loader state bridge for NativePHP Mobile with optional Blade and web view helpers",
  "type": "nativephp-plugin",
  "license": "MIT",
  "keywords": [
    "nativephp",
    "nativephp-plugin",
    "mobile",
    "loader"
  ],
  "support": {
    "issues": "https://github.com/SocialMobikul/Mobikul_Loader_Native_Php/issues"
  },
  "autoload": {
    "psr-4": {
      "MobikulLoader\\": "src/"
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "nativephp/mobile": "^3.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "MobikulLoader\\MobikulLoaderServiceProvider"
      ],
      "aliases": {
        "MobikulLoader": "MobikulLoader\\Facades\\MobikulLoader"
      }
    },
    "nativephp": {
      "manifest": "nativephp.json"
    }
  }
}
